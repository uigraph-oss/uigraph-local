dotenv

export DEV_HOSTNAME="${DEV_HOSTNAME:-localhost}"
export INFRA_HOSTNAME="${INFRA_HOSTNAME:-192.168.0.100}"

export UI_PORT="2180"
export API_PORT="2181"
export MCP_PORT="2187"
export GRAPHQL_PORT="2182"
export GATEWAY_PORT="2183"
export POSTGRES_PORT="2184"
export REDIS_PORT="2185"
export MINIO_PORT="2186"

UI_BASE="http://$DEV_HOSTNAME:$UI_PORT"
API_BASE="http://$DEV_HOSTNAME:$API_PORT"
MCP_BASE="http://$DEV_HOSTNAME:$MCP_PORT"
GRAPHQL_BASE="http://$DEV_HOSTNAME:$GRAPHQL_PORT"

# Postgres
export POSTGRES_DB="uigraph"
export POSTGRES_USER="uigraph"
export POSTGRES_PASSWORD="devpassword"

# Redis

# MinIO
export STORAGE_BUCKET="uigraph"
export STORAGE_ACCESS_KEY="uigraph"
export STORAGE_SECRET_KEY="devpassword"

# Frontend
export API_URL="$API_BASE"
export GRAPHQL_URL="$GRAPHQL_BASE"
export VITE_ASSETS_URL="http://$INFRA_HOSTNAME:$MINIO_PORT/uigraph"
export VITE_DEPLOY_ENV="local"

# Backend API
export UIGRAPH_PUBLIC_URL="$API_BASE"
export UIGRAPH_FRONTEND_URL="$UI_BASE"
export UIGRAPH_SECRET_KEY="dev-secret-key-32-bytes-long-!!!"
export POSTGRES_URL="postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@$INFRA_HOSTNAME:$POSTGRES_PORT/$POSTGRES_DB?sslmode=disable"
export REDIS_URL="redis://$INFRA_HOSTNAME:$REDIS_PORT"
export STORAGE_ENDPOINT="http://$INFRA_HOSTNAME:$MINIO_PORT"
export STORAGE_PUBLIC_ENDPOINT="http://$INFRA_HOSTNAME:$MINIO_PORT"

# Backend GraphQL
export API_BASE_URL="$API_BASE"
export ENV=local

# MCP Server
export UIGRAPH_API_URL="$API_BASE"
export UIGRAPH_FRONTEND_URL="$UI_BASE"
export UIGRAPH_MCP_PUBLIC_URL="$MCP_BASE"

# Backend Gateway
export UIGRAPH_API_URL="$API_BASE"
