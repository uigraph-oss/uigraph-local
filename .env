# Local development defaults for uigraph-local.
# These values match the docker-compose.yml defaults.
# Override by editing this file or exporting vars before running `make dev`.

# ═══════════════════════════════════════════════════════════════════════════════
# Shared infrastructure
# ═══════════════════════════════════════════════════════════════════════════════

POSTGRES_URL=postgres://uigraph:devpassword@localhost:5432/uigraph?sslmode=disable
REDIS_URL=redis://localhost:6379

STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=uigraph
STORAGE_ACCESS_KEY=uigraph
STORAGE_SECRET_KEY=devpassword
STORAGE_REGION=us-east-1
STORAGE_FORCE_PATH_STYLE=true

POSTGRES_PASSWORD=devpassword

# ═══════════════════════════════════════════════════════════════════════════════
# uigraph-api
# ═══════════════════════════════════════════════════════════════════════════════

UIGRAPH_SECRET_KEY=dev-secret-key-32-bytes-long-!!!
UIGRAPH_DOMAIN=localhost
UIGRAPH_PUBLIC_URL=http://localhost:3000
UIGRAPH_FRONTEND_URL=http://localhost:3000
UIGRAPH_ADDR=:8080

# ═══════════════════════════════════════════════════════════════════════════════
# uigraph-graphql
# ═══════════════════════════════════════════════════════════════════════════════

API_BASE_URL=http://localhost:8080
PORT=8090
ENV=local

# ═══════════════════════════════════════════════════════════════════════════════
# uigraph-gateway
# ═══════════════════════════════════════════════════════════════════════════════

UIGRAPH_API_URL=http://localhost:8080

# ═══════════════════════════════════════════════════════════════════════════════
# uigraph-ui
# ═══════════════════════════════════════════════════════════════════════════════

API_URL=http://localhost:8080
GRAPHQL_URL=http://localhost:8090
VITE_DEPLOY_ENV=local
VITE_ASSETS_URL=http://localhost:9000/uigraph
VITE_FEATURE_ENABLE_DEMO_TEST_CASES=false
CHOKIDAR_USEPOLLING=false
